# Sao chép từ .env.example và điền giá trị thật khi đã tạo MongoDB Cluster
SECRET_KEY=please-change-me-to-a-random-secret

# ====== MongoDB ======
# Sau khi tạo cluster trên MongoDB Atlas, dán connection string vào đây
MONGODB_URI=
MONGODB_DB=pfs_db
MONGODB_USERS_COLL=users
MONGODB_OTP_COLL=otp_codes

# ====== SMTP gửi OTP ======
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=Program For Student <no-reply@example.com>

OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN=60
